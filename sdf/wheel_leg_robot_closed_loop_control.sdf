          <friction>0.005</friction>
        </dynamics>
      </axis>
    </joint>

  
    <!-- ================= ros2_control: wheel velocity control ================= -->
    <ros2_control name="GazeboSystem" type="system">
      <hardware>
        <plugin>gazebo_ros2_control/GazeboSystem</plugin>
      </hardware>

      <joint name="wheel_1_joint">
        <command_interface name="velocity">
          <param name="min">-50</param>
          <param name="max">50</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>

      <joint name="wheel_2_joint">
        <command_interface name="velocity">
          <param name="min">-50</param>
          <param name="max">50</param>
        </command_interface>
        <state_interface name="position"/>
        <state_interface name="velocity"/>
      </joint>
    </ros2_control>

    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <parameters>/home/hby/foot_ws/src/wheel_leg_description/config/wheel_controllers.yaml</parameters>
    </plugin>

  
    <!-- ================= base pose / velocity output ================= -->
    <plugin name="base_odom" filename="libgazebo_ros_p3d.so">
      <ros>
        <namespace>/</namespace>
        <remapping>odom:=base_odom</remapping>
      </ros>
      <body_name>base_link</body_name>
      <frame_name>world</frame_name>
      <update_rate>100.0</update_rate>
      <gaussian_noise>0.0</gaussian_noise>
    </plugin>

  </model>
</sdf>
