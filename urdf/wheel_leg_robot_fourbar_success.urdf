      </geometry>
    </visual>
  </link>

  <joint name="wheel_1_joint" type="continuous">
    <parent link="small_leg_wheel_1_link"/>
    <child link="wheel_motor_1_link"/>
    <origin xyz="0.113521 -0.008000 -0.038897" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="LABEL_9_BLACK_WHEEL_MOTOR">
    <visual>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <material name="label_black"/>
    </visual>
  </link>

  <joint name="label_9_black_wheel_motor_joint" type="fixed">
    <parent link="wheel_motor_1_link"/>
    <child link="LABEL_9_BLACK_WHEEL_MOTOR"/>
    <origin xyz="0 0 0.030" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- big_arm_3_joint: red big arm -> magenta small_leggy_1 -->
  <!-- ========================================================= -->

  <link name="big_arm_3_link">
    <visual>
      <origin xyz="-0.231306 0.048436 -0.030643" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/big_arm_3.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="big_arm_3_joint" type="revolute">
    <parent link="base_link"/>
    <child link="big_arm_3_link"/>
    <origin xyz="0.231306 -0.048436 0.030643" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_3_RED_BIG_ARM">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_red"/>
    </visual>
  </link>

  <joint name="label_3_red_big_arm_joint" type="fixed">
    <parent link="big_arm_3_link"/>
    <child link="LABEL_3_RED_BIG_ARM"/>
    <origin xyz="0.038571 0.064500 -0.010596" rpy="0 0 0"/>
  </joint>


  <link name="small_leggy_1_link">
    <visual>
      <origin xyz="-0.308448 -0.080564 -0.009451" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/small_leggy_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="knee_3_joint" type="revolute">
    <parent link="big_arm_3_link"/>
    <child link="small_leggy_1_link"/>
    <origin xyz="0.077142 0.129000 -0.021192" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_7_MAGENTA_SMALL_LEGGY">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_magenta"/>
    </visual>
  </link>

  <joint name="label_7_magenta_small_leggy_joint" type="fixed">
    <parent link="small_leggy_1_link"/>
    <child link="LABEL_7_MAGENTA_SMALL_LEGGY"/>
    <origin xyz="-0.051814 0 -0.030254" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- big_arm_4_joint: yellow big arm -> yellow small_leggy_2 -->
  <!-- ========================================================= -->

  <link name="big_arm_4_link">
    <visual>
      <origin xyz="-0.161440 0.048436 -0.026313" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/big_arm_4.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="big_arm_4_joint" type="revolute">
    <parent link="base_link"/>
    <child link="big_arm_4_link"/>
    <origin xyz="0.161440 -0.048436 0.026313" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_4_YELLOW_BIG_ARM">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_yellow"/>
    </visual>
  </link>

  <joint name="label_4_yellow_big_arm_joint" type="fixed">
    <parent link="big_arm_4_link"/>
    <child link="LABEL_4_YELLOW_BIG_ARM"/>
    <origin xyz="-0.035530 -0.013500 -0.018375" rpy="0 0 0"/>
  </joint>


  <link name="small_leggy_2_link">
    <visual>
      <origin xyz="-0.090381 0.075436 0.010437" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/small_leggy_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="knee_4_joint" type="revolute">
    <parent link="big_arm_4_link"/>
    <child link="small_leggy_2_link"/>
    <origin xyz="-0.071059 -0.027000 -0.036750" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_8_YELLOW_SMALL_LEGGY">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_yellow"/>
    </visual>
  </link>

  <joint name="label_8_yellow_small_leggy_joint" type="fixed">
    <parent link="small_leggy_2_link"/>
    <child link="LABEL_8_YELLOW_SMALL_LEGGY"/>
    <origin xyz="0.055413 -0.004000 -0.023008" rpy="0 0 0"/>
  </joint>

</robot>
