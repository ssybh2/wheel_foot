<?xml version="1.0"?>
<robot name="wheel_leg_robot">

  <!-- ================= materials ================= -->
  <material name="base_gray">
    <color rgba="0.65 0.65 0.65 1"/>
  </material>

  <material name="label_red">
    <color rgba="1 0 0 1"/>
  </material>

  <material name="label_green">
    <color rgba="0 1 0 1"/>
  </material>

  <material name="label_blue">
    <color rgba="0 0.25 1 1"/>
  </material>

  <material name="label_yellow">
    <color rgba="1 1 0 1"/>
  </material>

  <material name="label_magenta">
    <color rgba="1 0 1 1"/>
  </material>

  <material name="label_cyan">
    <color rgba="0 1 1 1"/>
  </material>

  <material name="label_orange">
    <color rgba="1 0.45 0 1"/>
  </material>

  <material name="label_black">
    <color rgba="0.02 0.02 0.02 1"/>
  </material>


  <!-- ================= world ================= -->
  <link name="world"/>


  <!-- ================= base ================= -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/shell_and_big_motor.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="base_gray"/>
    </visual>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>


  <!-- base label -->
  <link name="LABEL_0_BASE">
    <visual>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <material name="label_black"/>
    </visual>
  </link>

  <joint name="label_0_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="LABEL_0_BASE"/>
    <origin xyz="0 0 0.080" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- big_arm_1_joint: blue big arm -> cyan small_leg_wheel_2 -> wheel_motor_2 -->
  <!-- ========================================================= -->

  <link name="big_arm_1_link">
    <visual>
      <origin xyz="-0.231306 -0.053564 -0.030643" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/big_arm_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="big_arm_1_joint" type="revolute">
    <parent link="base_link"/>
    <child link="big_arm_1_link"/>
    <origin xyz="0.231306 0.053564 0.030643" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_1_BLUE_BIG_ARM">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_blue"/>
    </visual>
  </link>

  <joint name="label_1_blue_big_arm_joint" type="fixed">
    <parent link="big_arm_1_link"/>
    <child link="LABEL_1_BLUE_BIG_ARM"/>
    <origin xyz="0.037350 -0.068500 -0.014319" rpy="0 0 0"/>
  </joint>


  <link name="small_leg_wheel_2_link">
    <visual>
      <origin xyz="-0.306005 0.083436 -0.002006" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/small_leg_wheel_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="knee_1_joint" type="revolute">
    <parent link="big_arm_1_link"/>
    <child link="small_leg_wheel_2_link"/>
    <origin xyz="0.074699 -0.137000 -0.028637" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_6_CYAN_SMALL_LEG_WHEEL">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_cyan"/>
    </visual>
  </link>

  <joint name="label_6_cyan_small_leg_wheel_joint" type="fixed">
    <parent link="small_leg_wheel_2_link"/>
    <child link="LABEL_6_CYAN_SMALL_LEG_WHEEL"/>
    <origin xyz="-0.052399 0 -0.029230" rpy="0 0 0"/>
  </joint>


  <link name="wheel_motor_2_link">
    <visual>
      <origin xyz="-0.201207 0.083436 0.056453" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/wheel_motor_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="wheel_2_joint" type="continuous">
    <parent link="small_leg_wheel_2_link"/>
    <child link="wheel_motor_2_link"/>
    <origin xyz="-0.104798 0 -0.058459" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="LABEL_10_BLACK_WHEEL_MOTOR">
    <visual>
      <geometry>
        <sphere radius="0.012"/>
      </geometry>
      <material name="label_black"/>
    </visual>
  </link>

  <joint name="label_10_black_wheel_motor_joint" type="fixed">
    <parent link="wheel_motor_2_link"/>
    <child link="LABEL_10_BLACK_WHEEL_MOTOR"/>
    <origin xyz="0 0 0.030" rpy="0 0 0"/>
  </joint>


  <!-- ========================================================= -->
  <!-- big_arm_2_joint: green big arm -> orange small_leg_wheel_1 -> wheel_motor_1 -->
  <!-- ========================================================= -->

  <link name="big_arm_2_link">
    <visual>
      <origin xyz="-0.161440 -0.053564 -0.026313" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/big_arm_2.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="big_arm_2_joint" type="revolute">
    <parent link="base_link"/>
    <child link="big_arm_2_link"/>
    <origin xyz="0.161440 0.053564 0.026313" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_2_GREEN_BIG_ARM">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_green"/>
    </visual>
  </link>

  <joint name="label_2_green_big_arm_joint" type="fixed">
    <parent link="big_arm_2_link"/>
    <child link="LABEL_2_GREEN_BIG_ARM"/>
    <origin xyz="-0.035071 0.017500 -0.019237" rpy="0 0 0"/>
  </joint>


  <link name="small_leg_wheel_1_link">
    <visual>
      <origin xyz="-0.091299 -0.088564 0.012160" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/small_leg_wheel_1.stl"
              scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
  </link>

  <joint name="knee_2_joint" type="revolute">
    <parent link="big_arm_2_link"/>
    <child link="small_leg_wheel_1_link"/>
    <origin xyz="-0.070141 0.035000 -0.038473" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="20" velocity="10"/>
  </joint>

  <link name="LABEL_5_ORANGE_SMALL_LEG_WHEEL">
    <visual>
      <geometry>
        <sphere radius="0.010"/>
      </geometry>
      <material name="label_orange"/>
    </visual>
  </link>

  <joint name="label_5_orange_small_leg_wheel_joint" type="fixed">
    <parent link="small_leg_wheel_1_link"/>
    <child link="LABEL_5_ORANGE_SMALL_LEG_WHEEL"/>
    <origin xyz="0.056761 -0.004000 -0.019449" rpy="0 0 0"/>
  </joint>


  <link name="wheel_motor_1_link">
    <visual>
      <origin xyz="-0.204820 -0.080564 0.051057" rpy="0 1.5708 0"/>
      <geometry>
        <mesh filename="package://wheel_leg_description/meshes/visual/wheel_motor_1.stl"
